# ═══════════════════════════════════════════════════════════════════════
#  CampusCoPilot — Environment Variables
#  See AZURE_API_SETUP_GUIDE.txt for full step-by-step instructions
# ═══════════════════════════════════════════════════════════════════════

# ── Azure AI Foundry (Llama endpoint) ────────────────────────────────
# This is the ONLY paid Azure service required.
# 1. Go to https://ai.azure.com → Models + endpoints → your Llama deployment
# 2. Copy the "Target URI" → paste below as AZURE_AI_ENDPOINT
# 3. Copy the "API Key"     → paste below as AZURE_AI_API_KEY
# 4. Your deployment name   → paste below as AZURE_AI_DEPLOYMENT
AZURE_AI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_AI_API_KEY=
AZURE_AI_DEPLOYMENT=
# ── Token guardrails (keep these low to save budget) ────────────────
MAX_INPUT_TOKENS=4096
MAX_OUTPUT_TOKENS=2048
TEMPERATURE=0.3

# ── ChromaDB (local vector store — no Azure service needed) ─────────
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=syllabus_chunks

# ── Server ──────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
HOST=0.0.0.0
PORT=8000

# ── MongoDB Atlas / Azure Cosmos DB for MongoDB API ────────────────
# OPTION A — MongoDB Atlas (free M0 tier):
#   1. https://www.mongodb.com/cloud/atlas/register → create free cluster
#   2. Atlas → Databases → Connect → Drivers → copy connection string
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/campuscopilot?retryWrites=true&w=majority
#
# OPTION B — Azure Cosmos DB (uncomment & replace the line above):
# MONGO_URI=mongodb://YOUR-ACCOUNT:KEY@YOUR-ACCOUNT.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&appName=@YOUR-ACCOUNT@
MONGO_DB_NAME=campuscopilot

# ── JWT Authentication ──────────────────────────────────────────────
# Generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE-ME-to-a-random-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Azure Document Intelligence (optional – falls back to PyPDF2) ──
# Go to: Azure Portal → Create "Document Intelligence" → Keys and Endpoint
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=

# ── Azure AI Search (optional – falls back to ChromaDB) ────────────
# Go to: Azure Portal → Create "AI Search" → Keys and Endpoint
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=neurixia-index
